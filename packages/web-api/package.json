{
  "name": "expo-gaode-map-web-api",
  "version": "2.0.4",
  "description": "AMap (Gaode Map) Web API toolkit for Expo/React Native: search, geocoding, and route planning in pure JavaScript.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf build",
    "lint": "node -e \"const { spawnSync } = require('child_process'); const r = spawnSync('tsc', ['--noEmit', '--pretty', 'false'], { stdio: 'inherit' }); process.exit(r.status ?? 1);\" --",
    "test": "bun test",
    "prepare": "yarn build"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-gaode-map-web-api",
    "expo-amap",
