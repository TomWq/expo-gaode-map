{
  "name": "expo-gaode-map-web-api",
  "version": "2.0.4",
  "description": "高德地图 Web API 服务 - 搜索、路径规划、地理编码（纯 JavaScript 实现，可独立使用，也可与 expo-gaode-map / expo-gaode-map-navigation 协同）",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./legacy": {
      "types": "./build/legacy.d.ts",
      "default": "./build/legacy.js"
    }
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf build",
    "lint": "node -e \"const { spawnSync } = require('child_process'); const r = spawnSync('tsc', ['--noEmit', '--pretty', 'false'], { stdio: 'inherit' }); process.exit(r.status ?? 1);\" --",
    "test": "bun test",
    "prepare": "yarn build",
    "prepublishOnly": "yarn --cwd ../.. check:shared-sync && yarn test && yarn build"
  },
  "keywords": [
    "react-native",
    "expo",
    "amap",
    "gaode",
    "web-api",
    "search",
    "geocode",
    "route",
    "高德地图"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TomWq/expo-gaode-map",
    "directory": "packages/web-api"
  },
  "bugs": {
    "url": "https://github.com/TomWq/expo-gaode-map/issues"
  },
  "author": "TomWq <582752848@qq.com> (https://github.com/TomWq)",
  "license": "MIT",
  "homepage": "https://tomwq.github.io/expo-gaode-map/",
  "devDependencies": {
    "@types/react": "~19.1.0",
    "bun-types": "^1.3.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react-native": "*"
  }
}
