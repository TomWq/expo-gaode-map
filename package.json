{
  "name": "expo-gaode-map-monorepo",
  "version": "2.2.26",
  "private": true,
  "workspaces": [
    "packages/*",
    "example",
    "example-navigation",
    "website"
  ],
  "description": "Expo / React Native 高德地图 Monorepo：Expo Modules、Config Plugin、地图定位、搜索、导航、离线地图与 Web API。",
  "scripts": {
    "build": "yarn build:core && yarn build:navigation && yarn build:web-api",
    "build:core": "cd packages/core && expo-module build && cd plugin && tsc",
    "build:navigation": "cd packages/navigation && expo-module build",
    "build:web-api": "cd packages/web-api && yarn build",
    "clean": "yarn clean:core && yarn clean:navigation && yarn clean:web-api",
    "clean:core": "cd packages/core && yarn clean",
    "clean:navigation": "cd packages/navigation && yarn clean",
    "clean:web-api": "cd packages/web-api && yarn clean",
    "lint": "yarn lint:core && yarn lint:navigation && yarn lint:web-api",
    "lint:core": "cd packages/core && yarn lint",
    "lint:navigation": "cd packages/navigation && yarn lint",
    "lint:web-api": "cd packages/web-api && yarn lint",
    "test": "yarn test:core && yarn test:navigation && yarn test:web-api",
    "test:core": "cd packages/core && yarn test",
    "test:navigation": "cd packages/navigation && yarn test",
    "test:web-api": "cd packages/web-api && yarn test",
    "test:example-navigation": "cd example-navigation && npm test -- --runInBand",
    "android:example-navigation:compile": "cd example-navigation/android && ./gradlew :app:compileDebugKotlin",
    "verify": "yarn test && yarn test:example-navigation",
    "publish:core": "cd packages/core && npm publish --access public",
    "publish:navigation": "cd packages/navigation && npm publish --access public",
    "publish:web-api": "cd packages/web-api && npm publish --access public",
    "publish:core:beta": "cd packages/core && npm publish --access public --tag beta",
    "publish:navigation:beta": "cd packages/navigation && npm publish --access public --tag beta",
    "publish:web-api:beta": "cd packages/web-api && npm publish --access public --tag beta",
    "npm:login": "npm login --auth-type=web --registry=https://registry.npmjs.org/",
    "publish:interactive": "bash scripts/publish.sh",
    "version:core": "cd packages/core && npm version",
    "version:navigation": "cd packages/navigation && npm version",
    "version:web-api": "cd packages/web-api && npm version",
    "version:core:beta": "cd packages/core && npm version prerelease --preid=beta --no-git-tag-version",
    "version:navigation:beta": "cd packages/navigation && npm version prerelease --preid=beta --no-git-tag-version",
    "version:web-api:beta": "cd packages/web-api && npm version prerelease --preid=beta --no-git-tag-version",
    "android": "yarn run:android",
    "ios": "yarn run:ios"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.1",
    "expo": "^57.0.1",
    "expo-module-scripts": "^56.0.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "expo": ">=54.0.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "resolutions": {
    "uuid@npm:^7.0.3": "npm:11.1.1"
  },
  "packageManager": "yarn@4.12.0"
}
