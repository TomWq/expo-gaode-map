{
  "expo": {
    "name": "expo-gaode-map-example",
    "slug": "expo-gaode-map-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "expo-gaode-map-example",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "expo.modules.gaodemap.example"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "expo.modules.gaodemap.example"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "react-native-splash-screen-newarch",
        {
          "image": "./assets/splash-map-full.png",
          "backgroundColor": "#F5FBF8",
          "resizeMode": "cover",
          "android": {
            "fullScreen": true,
            "createLayout": true,
            "overwriteLayout": true,
            "backgroundColor": "#F5FBF8",
            "image": "./assets/splash-map-full.png",
            "imageResizeMode": "centerCrop",
            "imageGravity": "center",
            "systemImage": false,
            "windowIsTranslucent": false
          },
          "ios": {
            "image": "./assets/splash-map-full.png",
            "backgroundColor": "#F5FBF8",
            "resizeMode": "cover"
          }
        }
      ],
      [
        "expo-gaode-map",
        {
          "iosKey": "dce6256823267916825743c01fedc375",
          "androidKey": "db755ae42443bcdff6a796409f6860f9",
          "enableLocation": true,
          "locationDescription": "我们需要访问您的位置信息以提供地图服务",
          "enableBackgroundLocation": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "我们需要访问您的相册以保存地图截图。",
          "savePhotosPermission": "我们需要保存图片到您的相册。",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-status-bar"
    ]
  }
}
