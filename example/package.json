    "expo-gaode-map": "workspace:*",
    "expo-gaode-map-web-api": "workspace:*",
    "expo-linking": "~57.0.1",
    "expo-media-library": "~57.0.0",
    "expo-router": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-splash-screen-newarch": "^2.0.2",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~57.0.0",
    "typescript": "~6.0.3"
  },
  "expo": {
